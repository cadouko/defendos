CSS = b"""
window {
    background-color: #1a1a2e;
    color: #e0e0e0;
}
.sidebar {
    background-color: #16213e;
    border-right: 1px solid #0f3460;
    min-width: 200px;
}
.cat-btn {
    background: transparent;
    border: none;
    color: #a0a0c0;
    padding: 14px 20px;
    text-align: left;
    font-size: 14px;
    border-radius: 0;
    transition: all 0.2s;
}
.cat-btn:hover, .cat-btn.active {
    background-color: #0f3460;
    color: #e0e0ff;
    border-left: 3px solid #e94560;
}
.tool-card {
    background-color: #16213e;
    border: 1px solid #0f3460;
    border-radius: 8px;
    margin: 6px;
    padding: 14px;
    transition: all 0.2s;
}
.tool-card:hover {
    background-color: #0f3460;
    border-color: #e94560;
}
