#!/bin/sh
# DefendOS – live-build auto/config
set -e

cd "$(dirname "$0")/.."

lb config \
    --mode debian \
    --distribution bookworm \
    --archive-areas "main contrib non-free non-free-firmware" \
    --apt-indices false \
    --apt-recommends false \
    --apt-source-archives false \
    --syslinux-theme live-build \
    \
    --bootappend-live \
        "boot=live components quiet splash \
         username=root hostname=defendos \
         toram \
         systemd.unified_cgroup_hierarchy=1" \
    \
    --debian-installer false \
    \
    --iso-application "DefendOS - Cybersecurity Live OS" \
    --iso-publisher "DefendOS Project" \
    --iso-volume "DefendOS_$(date +%Y%m)" \
    \
    --linux-flavours amd64 \
    --linux-packages "linux-image-amd64" \
    \
    --mirror-bootstrap    "http://deb.debian.org/debian" \
    --mirror-chroot       "http://deb.debian.org/debian" \
    --security false \
    --mirror-binary       "http://deb.debian.org/debian" \
    --mirror-binary-security "http://security.debian.org/debian-security" \
    \
    --checksums sha256 \
    \
    "${@}"

#
# Post-config: populate bootloader files from host system packages.
# lb_binary_syslinux with --syslinux-theme live-build copies from
# config/bootloaders/isolinux/.  The live-build package ships zero-byte
# stubs, so we replace them with the real binaries installed on the host.
#
mkdir -p config/bootloaders/isolinux

_installed_bootloader_files()
{
	# Copy isolinux.bin from the ISOLINUX package (host)
	if [ -f /usr/lib/ISOLINUX/isolinux.bin ]
	then
		cp -aL /usr/lib/ISOLINUX/isolinux.bin config/bootloaders/isolinux/
	fi

	# Copy all syslinux BIOS modules (vesamenu.c32, etc.)
	if [ -d /usr/lib/syslinux/modules/bios ]
	then
		cp -aL /usr/lib/syslinux/modules/bios/*.c32 \
			config/bootloaders/isolinux/ 2>/dev/null || true
	fi
}

_installed_bootloader_files

# Warn if isolinux.bin is still missing (the live-build stub is 0 bytes)
if [ ! -s config/bootloaders/isolinux/isolinux.bin ]
then
	echo "WARNING: isolinux.bin not found on host (0-byte stub may be used)" >&2
fi
