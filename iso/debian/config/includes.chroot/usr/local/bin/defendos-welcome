#!/usr/bin/env python3
"""
DefendOS – Écran de bienvenue (affiché au premier démarrage du live)
"""

import gi
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk, GLib
import subprocess
import os

CSS = b"""
window {
    background-color: #0d0d1a;
}
.welcome-title {
    font-size: 36px;
    font-weight: bold;
    color: #e94560;
}
.welcome-sub {
    font-size: 16px;
    color: #8888bb;
    margin-top: 6px;
}
.welcome-card {
    background-color: #16213e;
    border: 1px solid #0f3460;
    border-radius: 12px;
    padding: 20px;
    margin: 10px;
}
.card-title {
    font-size: 14px;
    font-weight: bold;
    color: #e0e0ff;
}
.card-desc {
    font-size: 12px;
    color: #8888aa;
    margin-top: 4px;
}
.action-btn {
    background-color: #e94560;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 12px 28px;
    font-size: 14px;
    font-weight: bold;
}
.action-btn:hover {
    background-color: #c73652;
}
.secondary-btn {
    background-color: #0f3460;
    color: #aaaacc;
    border: 1px solid #2a2a5a;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 12px;
}
.warning-box {
    background-color: #2d1a00;
    border: 1px solid #e67e22;
    border-radius: 8px;
    padding: 12px 16px;
    margin: 8px 0;
}
.warning-text {
    color: #e67e22;
    font-size: 12px;
}
"""

FEATURES = [
    ("🔴", "Red Team / Pentest", "Metasploit, Nuclei, SQLMap, ffuf, Burp Suite, Nmap, Hashcat..."),
    ("🔵", "Blue Team / Défense", "Suricata IDS, Zeek, Wazuh, Lynis, Fail2Ban, ClamAV, Auditd..."),
    ("🟣", "Forensics / RE", "Volatility3, Autopsy, Binwalk, Radare2, GDB+pwndbg, Foremost..."),
    ("⚙️", "Hardening système", "SSH, sysctl, AppArmor, auditd, UFW – configuration sécurisée"),
]


class WelcomeWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="DefendOS – Bienvenue")
        self.set_default_size(800, 600)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_resizable(False)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        self._build()

    def _build(self):
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        vbox.set_margin_top(40)
        vbox.set_margin_bottom(30)
        vbox.set_margin_start(50)
        vbox.set_margin_end(50)
        self.add(vbox)

        # Titre
        title = Gtk.Label(label="⚔️  DefendOS")
        title.get_style_context().add_class("welcome-title")
        vbox.pack_start(title, False, False, 0)

        sub = Gtk.Label(label="Distribution cybersécurité – Arch Linux + BlackArch  |  Mode Live")
        sub.get_style_context().add_class("welcome-sub")
        vbox.pack_start(sub, False, False, 0)

        # Avertissement légal
        warn_box = Gtk.Box()
        warn_box.get_style_context().add_class("warning-box")
        warn_box.set_margin_top(20)
        warn_lbl = Gtk.Label(label=(
            "⚠️  USAGE ÉTHIQUE UNIQUEMENT – Ces outils sont destinés aux tests d'intrusion "
            "autorisés, à la recherche en sécurité et à la défense de systèmes dont vous êtes "
            "propriétaire ou avez l'autorisation explicite. Toute utilisation non autorisée est "
            "illégale."
        ))
        warn_lbl.set_line_wrap(True)
        warn_lbl.set_xalign(0)
        warn_lbl.get_style_context().add_class("warning-text")
        warn_box.pack_start(warn_lbl, True, True, 8)
        vbox.pack_start(warn_box, False, False, 0)

        # Features grid
        grid = Gtk.Grid()
        grid.set_row_spacing(0)
        grid.set_column_spacing(0)
        grid.set_margin_top(20)

        for i, (icon, title_txt, desc_txt) in enumerate(FEATURES):
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            card.get_style_context().add_class("welcome-card")

            h = Gtk.Box(spacing=8)
            h.pack_start(Gtk.Label(label=icon), False, False, 0)
            t = Gtk.Label(label=title_txt)
            t.get_style_context().add_class("card-title")
            h.pack_start(t, False, False, 0)
            card.pack_start(h, False, False, 0)

            d = Gtk.Label(label=desc_txt)
            d.set_line_wrap(True)
            d.set_xalign(0)
            d.get_style_context().add_class("card-desc")
            card.pack_start(d, False, False, 0)

            grid.attach(card, i % 2, i // 2, 1, 1)

        vbox.pack_start(grid, True, True, 0)

        # Boutons
        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)
        btn_box.set_margin_top(24)
        btn_box.set_halign(Gtk.Align.CENTER)

        btn_launch = Gtk.Button(label="🚀 Ouvrir le Launcher")
        btn_launch.get_style_context().add_class("action-btn")
        btn_launch.connect("clicked", self._launch_gui)
        btn_box.pack_start(btn_launch, False, False, 0)

        btn_term = Gtk.Button(label="🖥  Terminal")
        btn_term.get_style_context().add_class("secondary-btn")
        btn_term.connect("clicked", lambda b: subprocess.Popen("xfce4-terminal", shell=True))
        btn_box.pack_start(btn_term, False, False, 0)

        btn_close = Gtk.Button(label="✕ Fermer")
        btn_close.get_style_context().add_class("secondary-btn")
        btn_close.connect("clicked", lambda b: Gtk.main_quit())
        btn_box.pack_start(btn_close, False, False, 0)

        vbox.pack_start(btn_box, False, False, 0)
        self.show_all()

    def _launch_gui(self, btn):
        subprocess.Popen("defendos-gui", shell=True)
        Gtk.main_quit()


def main():
    win = WelcomeWindow()
    win.connect("destroy", Gtk.main_quit)
    Gtk.main()


if __name__ == "__main__":
    main()
